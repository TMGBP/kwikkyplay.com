<div id="support" class="pt-32">
   {% set title = support.help_title %}
   {% include "sectionTitle.njk" %}
   <ul class="text-body list-disc list-inside">
      {% for text in support.list %}
         <li>{{ text }}</li>
      {% endfor %}
   </ul>
   <div class="mt-12 flex md:items-center flex-col md:flex-row gap-4 lg:gap-8">
      {% set title = support.langs_title %}
      {% set removeMargin = true %}
      {% include "sectionTitle.njk" %}

      {% set type = "support" %}
      {% include "lang-selector.njk" %}
   </div>
   <div class="mt-32">
      {% set title = support.license_title %}
      {% set removeMargin = false %}
      {% include "sectionTitle.njk" %}
      <p class="text-body">
         {{ support.license_text }}
      </p>
   </div>
   <div class="mt-16">
      {% set title = support.gaming_title%}
      {% set removeMargin = false %}
      {% set variant = "small" %}
      {% include "sectionTitle.njk" %}
      <p class="text-body">
         {{ support.gaming_text }}
      </p>
   </div>
   <div class="mt-16 max-w-2xl mx-auto grid grid-cols-3 gap-3 items-center justify-center">
      {% if support.gaming_icons %}
         {% for icon in support.gaming_icons %}
            <div class="flex flex-col items-center justify-center gap-4">
               <img loading="lazy" src="{{ icon.image }}" alt="{{ icon.alt }}" class="size-[80px] md:size-[148px] pointer-events-none">
               <p class="font-2 font-bold support-icon-title text-center">{{ icon.title }}</p>
            </div>
         {% endfor %}
      {% endif %}
   </div>
</div>

<style>
   .support-icon-title {
      font-size: {{ fonts.text_sizes.bodySm }};
   }
   @media (min-width: 768px) {
      .support-icon-title {
         font-size: {{ fonts.text_sizes.bodyLg }};
      }
   }
   
</style>
