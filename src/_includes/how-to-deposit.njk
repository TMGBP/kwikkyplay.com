<section id="how-to-deposit" class="pt-24 lg:pt-32">
   <div class="max-w-7xl mx-auto">
      <div class="max-w-5xl">
         {% if how_to_deposit.eyebrow %}
            <span class="how-deposit-kicker">
               {{ how_to_deposit.eyebrow }}
            </span>
         {% endif %}

         <h2 class="section-title-small font-bold leading-tight mt-4 mb-5">
            {{ how_to_deposit.title }}
         </h2>

         <p class="text-body leading-relaxed how-deposit-intro">
            {{ how_to_deposit.description }}
         </p>
      </div>

      <div class="how-deposit-steps">
         {% for step in how_to_deposit.steps %}
            <article class="how-deposit-card">
               <div class="how-deposit-content">
                  <div class="how-deposit-number">
                     {{ step.number }}
                  </div>

                  <h3 class="how-deposit-step-title">
                     {{ step.title }}
                  </h3>

                  <p class="how-deposit-step-text">
                     {{ step.description }}
                  </p>
               </div>

               <div class="how-deposit-image-wrap">
                  <img
                     loading="lazy"
                     src="{{ step.image }}"
                     alt="{{ step.image_alt }}"
                     class="how-deposit-image"
                  >
               </div>
            </article>
         {% endfor %}
      </div>

      {% if how_to_deposit.note %}
         <p class="how-deposit-note text-body-sm">
            {{ how_to_deposit.note }}
         </p>
      {% endif %}
   </div>
</section>

<style>
   #how-to-deposit {
      scroll-margin-top: 120px;
   }

   .how-deposit-kicker {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      padding: 7px 13px;
      border-radius: 999px;
      background: #fff2ec;
      border: 1px solid #ff8b63;
      color: #ff5f35;
      font-size: 13px;
      line-height: 1;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
   }

   .how-deposit-intro {
      max-width: 940px;
      margin-bottom: 0;
   }

   .how-deposit-steps {
      display: grid;
      gap: 28px;
      margin-top: 46px;
   }

   .how-deposit-card {
      display: grid;
      grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.48fr);
      gap: 26px;
      align-items: center;
      padding: 18px;
      border-radius: 28px;
      background:
         radial-gradient(circle at top left, rgba(255, 116, 79, 0.22), transparent 32%),
         linear-gradient(135deg, #fff4ed 0%, #ffe8dd 48%, #fff8f4 100%);
      border: 1px solid rgba(255, 116, 79, 0.28);
      box-shadow: 0 18px 45px rgba(255, 116, 79, 0.14);
      overflow: hidden;
   }

   .how-deposit-card:nth-child(even) {
      grid-template-columns: minmax(0, 1.48fr) minmax(0, 0.92fr);
   }

   .how-deposit-card:nth-child(even) .how-deposit-content {
      order: 2;
   }

   .how-deposit-card:nth-child(even) .how-deposit-image-wrap {
      order: 1;
   }

   .how-deposit-content {
      padding: 14px;
   }

   .how-deposit-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 48px;
      height: 48px;
      padding: 0 12px;
      border-radius: 16px;
      background: #ff5f35;
      color: #ffffff;
      font-size: 16px;
      line-height: 1;
      font-weight: 900;
      box-shadow: 0 10px 24px rgba(255, 95, 53, 0.28);
   }

   .how-deposit-step-title {
      margin: 18px 0 10px;
      color: #101010;
      font-size: 22px;
      line-height: 1.25;
      font-weight: 900;
   }

   .how-deposit-step-text {
      margin: 0;
      color: rgba(16, 16, 16, 0.74);
      font-size: 16px;
      line-height: 1.65;
   }

   .how-deposit-image-wrap {
      position: relative;
      border-radius: 22px;
      padding: 10px;
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid rgba(255, 116, 79, 0.18);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.45);
      overflow: hidden;
   }

   .how-deposit-image-wrap::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      border-radius: inherit;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.32), rgba(255, 255, 255, 0));
      z-index: 1;
   }

   .how-deposit-image {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 16px;
      object-fit: cover;
      position: relative;
      z-index: 0;
   }

   .how-deposit-note {
      margin-top: 26px;
      max-width: 980px;
      color: rgba(16, 16, 16, 0.68);
      line-height: 1.6;
   }

   @media (max-width: 1023px) {
      .how-deposit-card,
      .how-deposit-card:nth-child(even) {
         grid-template-columns: 1fr;
      }

      .how-deposit-card:nth-child(even) .how-deposit-content,
      .how-deposit-card:nth-child(even) .how-deposit-image-wrap {
         order: initial;
      }

      .how-deposit-content {
         padding: 8px 6px 0;
      }
   }

   @media (max-width: 767px) {
      .how-deposit-steps {
         gap: 22px;
         margin-top: 38px;
      }

      .how-deposit-card {
         padding: 14px;
         border-radius: 22px;
      }

      .how-deposit-number {
         min-width: 42px;
         height: 42px;
         border-radius: 14px;
         font-size: 14px;
      }

      .how-deposit-step-title {
         font-size: 20px;
         margin-top: 16px;
      }

      .how-deposit-step-text {
         font-size: 15px;
      }

      .how-deposit-image-wrap {
         border-radius: 18px;
         padding: 8px;
      }

      .how-deposit-image {
         border-radius: 13px;
      }
   }
</style>